{
  "name": "server-api",
  "version": "1.0.0",
  "description": "Node.js Express API for mobile app",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "watch": "tsc -w",
    "test:daily-logs": "ts-node src/scripts/testDailyLogs.ts",
    "test:supabase": "ts-node src/scripts/testSupabaseConnection.ts",
    "migrate": "ts-node src/scripts/runMigration.ts",
    "validate:bloodwork": "ts-node src/scripts/validateBloodworkUpload.ts",
    "validate:extraction": "ts-node src/scripts/validateBloodworkExtraction.ts",
    "validate:e2e": "ts-node src/scripts/validateExtractionE2E.ts",
    "validate:trends": "ts-node src/scripts/validateBloodworkTrends.ts",
    "validate:trends:e2e": "ts-node src/scripts/validateTrendsE2E.ts",
    "validate:recommendations": "ts-node src/scripts/validateBloodworkRecommendations.ts",
    "validate:intelligence:e2e": "ts-node src/scripts/validateIntelligenceE2E.ts",
    "validate:intelligence": "ts-node src/scripts/validateBloodworkIntelligence.ts",
    "validate:health-inputs": "ts-node src/scripts/validateHealthInputEndpoints.ts",
    "validate:health-inputs:negative": "ts-node src/scripts/validateHealthInputNegativeCases.ts",
    "validate:health-inputs:all": "npm run validate:health-inputs && npm run validate:health-inputs:negative",
    "validate:interview-loop": "ts-node src/scripts/validateInterviewAgentLoop.ts",
    "validate:workout-engine": "ts-node src/scripts/validateWorkoutEngineE2E.ts",
    "validate:supplement-engine": "ts-node src/scripts/validateSupplementEngineE2E.ts",
    "validate:recovery-engine": "ts-node src/scripts/validateRecoveryEngineE2E.ts",
    "validate:stress-engine": "ts-node src/scripts/validateStressEngineE2E.ts",
    "validate:joint-health-engine": "ts-node src/scripts/validateJointHealthEngineE2E.ts",
    "validate:adherence-engine": "ts-node src/scripts/validateAdherenceEngineE2E.ts",
    "validate:dynamic-followups": "ts-node src/scripts/validateDynamicFollowUpsE2E.ts",
    "validate:notification-flow": "ts-node src/scripts/validateNotificationFlowE2E.ts",
    "validate:save-back": "ts-node src/scripts/validateSaveBackE2E.ts",
    "validate:health-data-hub": "ts-node src/scripts/validateHealthDataHubE2E.ts",
    "validate:ocr": "ts-node src/scripts/validateOCRPipeline.ts",
    "deploy:recommendations-schema": "ts-node src/scripts/deployRecommendationsSchema.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "axios": "^1.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "multer": "^2.1.1",
    "openai": "^4.28.4",
    "pdf-parse": "^1.1.4",
    "tesseract.js": "^5.1.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/connect": "^3.4.38",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/qs": "^6.15.0",
    "@types/range-parser": "^1.2.7",
    "@types/send": "^1.2.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
