# Workout Service Integration
# Set to true to use the integrated workout service with progressive overload
# Set to false to use the basic workout service (default)
EXPO_PUBLIC_USE_INTEGRATED_WORKOUT=true

# Enhanced Progressive Overload (V3)
# Set to true to enable AI overload, exercise classification, training phase logic
# Set to false to use simple overload (default)
   EXPO_PUBLIC_USE_ENHANCED_OVERLOAD=true
   EXPO_PUBLIC_API_URL=http://localhost:3001

# Oura Integration (Public Client ID - Safe to Expose)
# EXPO_PUBLIC_OURA_CLIENT_ID=your-client-id

# Automatic Background Sync for Apple Health
# Set to true to enable automatic background sync for blood pressure and Apple Watch data
# Set to false to disable automatic sync (manual sync only)
EXPO_PUBLIC_ENABLE_BACKGROUND_SYNC=true