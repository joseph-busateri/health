+
+    if (dbError) {
+      logger.error('❌ [METABOLIC ENGINE V2] Failed to persist to database', {
+        error: dbError.message,
+      });
+    } else {
+      logger.info('✅ [METABOLIC ENGINE V2] Persisted to database');
