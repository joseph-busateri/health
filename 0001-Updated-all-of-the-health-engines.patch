+import type {
+  PerformanceStatus,
+  PerformanceSourceInputs,
+  PerformanceRecommendation,
+  PerformanceRecord,
+  PerformanceScoreBreakdown,
+  PerformanceEvidence,
+  PerformanceEvidenceSignal,
