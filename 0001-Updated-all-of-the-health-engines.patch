+      table: 'bloodwork_results',
+      field: 'hdl',
+    },
+    lastUpdated: bloodwork?.latestTestDate,
+    unit: 'mg/dL',
+    category: 'bloodwork',
+  });
+
+  // LDL Cholesterol - use actual DB value
